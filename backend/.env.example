# RAKSHA AI — Environment Configuration

# ── Gemma 4 via Google AI API (cloud/online mode) ──
GOOGLE_API_KEY=your_google_ai_api_key_here
GEMMA_CLOUD_MODEL=gemma-4-27b-it

# ── Ollama (offline/local mode) ──
OLLAMA_BASE_URL=http://localhost:11434
GEMMA_LOCAL_MODEL=gemma4:4b

# ── Database ──
DATABASE_URL=./raksha.db

# ── Security ──
SECRET_KEY=change_this_to_a_strong_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Application ──
APP_NAME=RAKSHA AI
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","https://raksha-ai.onrender.com"]

# ── Map Settings ──
DEFAULT_LAT=20.5937
DEFAULT_LNG=78.9629
DEFAULT_ZOOM=5
