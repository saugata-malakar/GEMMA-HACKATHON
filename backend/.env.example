# RAKSHA AI Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# GOOGLE GEMMA API CONFIGURATION
# ==========================================
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ==========================================
# GEMMA MODEL CONFIGURATION
# ==========================================
# Cloud model (when internet is available)
GEMMA_CLOUD_MODEL=google/gemini-1.5-flash

# Local model (for offline mode via Ollama)
# Options: gemma:4b, gemma2:27b, mistral, llama3.2-vision
GEMMA_LOCAL_MODEL=gemma:4b

# ==========================================
# OLLAMA CONFIGURATION (Optional - for local AI)
# ==========================================
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ==========================================
# HUGGINGFACE CONFIGURATION (Optional - for vision)
# ==========================================
# Get your token from: https://huggingface.co/settings/tokens
# This improves BLIP captioning rate limits
HUGGINGFACE_TOKEN=

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# SQLite database path (no changes needed for default)
DATABASE_URL=/app/data/raksha.db

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=8000
DEBUG=false

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=["*"]

# ==========================================
# AI FALLBACK CONFIGURATION
# ==========================================
# Use Pollinations free AI as fallback when Gemini is unavailable
USE_POLLINATIONS_FALLBACK=true